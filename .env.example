# ============================================================
# MyGrad — Environment Configuration
# ============================================================
# Copy this file to .env and edit with YOUR credentials:
#
#   cp .env.example .env
#
# The app reads these at startup. Never commit .env to git.
# ============================================================

# -----------------------------------------------------------
# SQL Server Connection
# -----------------------------------------------------------
# Server name (use . for local, localhost, or hostname\instance)
SQL_SERVER=.

# Database name
SQL_DATABASE=TestDB

# -----------------------------------------------------------
# Authentication — choose ONE of the two options below
# -----------------------------------------------------------

# OPTION 1: Windows Authentication (default — no password needed)
# Just log in with your Windows account. Works out of the box on most setups.
SQL_TRUSTED_CONNECTION=yes

# OPTION 2: SQL Server Authentication (uncomment and fill in)
# SQL_TRUSTED_CONNECTION=no
# SQL_USERNAME=sa
# SQL_PASSWORD=YourPasswordHere

# -----------------------------------------------------------
# ODBC Driver (change only if you have a different version)
# -----------------------------------------------------------
# SQL_DRIVER={ODBC Driver 17 for SQL Server}

# -----------------------------------------------------------
# Flask (optional)
# -----------------------------------------------------------
# SECRET_KEY=change-me-to-a-random-string
